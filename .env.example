# Copy this file to .env and fill in values. .env is gitignored.

# --- Gradio UI (gradio_ui.py) ---
WORKER_URL=https://your-worker.workers.dev
# At least one of OPENROUTER_API_KEY or GEMINI_API_KEY is required for Q&A.
OPENROUTER_API_KEY=
# Google AI Studio key (https://aistudio.google.com/apikey) — direct Gemini API
GEMINI_API_KEY=
# Optional overrides:
# OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
# DEFAULT_MODEL=google/gemini-2.5-flash
# DEFAULT_GEMINI_MODEL=gemini-2.0-flash
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
# DEFAULT_LLM_PROVIDER=openrouter
# OPENROUTER_HTTP_REFERER=https://github.com/yourusername/cloud-federated-rag
# OPENROUTER_X_TITLE=cloud-federated-rag

# --- Laptop worker (laptop_worker.py) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=
SUPABASE_TABLE=document_chunks
# Optional:
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DIM=384

# --- Cloudflare Worker (worker.js) — set in Dashboard → Workers → your worker → Settings → Variables ---
# SUPABASE_URL
# SUPABASE_KEY
# SUPABASE_TABLE (optional, default document_chunks)
